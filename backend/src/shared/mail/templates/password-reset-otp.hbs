<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Reset your AjoFlow password</title>
	</head>
	<body style="margin:0;background:#f6f3ec;font-family:Arial,Helvetica,sans-serif;color:#151515;">
		<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f6f3ec;padding:32px 16px;">
			<tr>
				<td align="center">
					<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px;background:#ffffff;border-radius:28px;overflow:hidden;box-shadow:0 24px 70px rgba(11,20,40,0.12);">
						<tr>
							<td style="background:linear-gradient(140deg,#231e28 0%,#0b1428 52%,#111717 100%);padding:34px;">
								<table role="presentation" width="100%" cellspacing="0" cellpadding="0">
									<tr>
										<td><div style="width:46px;height:46px;line-height:46px;text-align:center;border-radius:14px;background:#22283b;color:#e1ad2d;font-size:26px;font-weight:900;">A</div></td>
										<td align="right" style="color:#a9b2c8;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Password Reset</td>
									</tr>
								</table>
								<h1 style="margin:36px 0 10px;color:#ffffff;font-size:34px;line-height:1.12;font-weight:900;">Reset your password</h1>
								<p style="margin:0;color:#a9b2c8;font-size:16px;line-height:1.7;">Hi {{name}}, use this code to confirm your password reset request.</p>
							</td>
						</tr>
						<tr>
							<td style="padding:36px 34px 12px;">
								<div style="border-radius:24px;background:#fffaf1;border:1px solid #ece8e0;padding:30px;text-align:center;">
									<div style="display:inline-block;margin-bottom:18px;padding:10px 14px;border-radius:999px;background:#f4f1ec;color:#9b5f43;font-size:12px;font-weight:900;letter-spacing:1.6px;text-transform:uppercase;">One-time reset code</div>
									<div style="font-size:42px;line-height:1;font-weight:900;letter-spacing:10px;color:#101010;">{{code}}</div>
									<p style="margin:18px 0 0;color:#697386;font-size:14px;">Expires in {{expiresIn}}</p>
								</div>
							</td>
						</tr>
						<tr>
							<td style="padding:18px 34px 34px;">
								<p style="margin:0;color:#697386;font-size:15px;line-height:1.75;">For your protection, never share this code with anyone. AjoFlow will never ask for your password or OTP outside the app.</p>
								<div style="margin-top:28px;padding:18px;border-radius:18px;background:#f4f1ec;color:#697386;font-size:13px;line-height:1.6;">
									If this was not you, contact <a href="mailto:{{supportEmail}}" style="color:#9b5f43;font-weight:800;text-decoration:none;">{{supportEmail}}</a> right away.
								</div>
							</td>
						</tr>
					</table>
					<p style="margin:22px 0 0;color:#a2a9b8;font-size:12px;">&copy; {{year}} AjoFlow. Community savings made simple.</p>
				</td>
			</tr>
		</table>
	</body>
</html>
