{
	"expo": {
		"name": "AjoFlow",
		"slug": "ajoflow",
		"scheme": "ajoflow",
		"version": "1.0.0",
		"orientation": "portrait",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"jsEngine": "hermes",
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.samscript.ajoflow",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.samscript.ajoflow"
		},
		"plugins": ["expo-router", "expo-font", "expo-web-browser", "expo-secure-store"],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
